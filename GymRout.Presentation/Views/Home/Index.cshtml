

<body class="gym-home">
    <div class="gym-scroll-progress" aria-hidden="true">
        <span class="gym-scroll-progress__bar"></span>
    </div>

   
    <main>
        <!-- Hero -->
        <section class="gym-hero" id="top">
            <div class="gym-hero__bg" aria-hidden="true">
                <div class="gym-hero__grain"></div>
                <div class="gym-hero__orb gym-hero__orb--1"></div>
                <div class="gym-hero__orb gym-hero__orb--2"></div>
                <div class="gym-hero__grid"></div>
            </div>

            <div class="container position-relative">
                <div class="row align-items-center g-4 g-lg-5">
                    <div class="col-lg-6 gym-hero__media-col gym-reveal gym-reveal--left">
                        <div class="gym-hero__visual" data-parallax>
                            <div class="gym-hero__accent-block" aria-hidden="true"></div>
                            <div class="gym-hero__frame">
                                <img src="~/images/home/hero.jpg" alt="Athlete lifting weights in the gym" />
                            </div>
                            <div class="gym-hero__thumb d-none d-md-block">
                                <img src="~/images/home/about-side1.jpg" alt="Gym training session" />
                            </div>
                            <div class="gym-hero__float-card gym-hero__float-card--1 d-none d-md-flex">
                                <span class="gym-icon-circle"><i class="bi bi-clock-fill"></i></span>
                                <div>
                                    <strong>24/7</strong>
                                    <small class="d-block text-muted">Gym access</small>
                                </div>
                            </div>
                            <div class="gym-hero__float-card gym-hero__float-card--2 d-none d-md-flex">
                                <span class="gym-icon-circle"><i class="bi bi-calendar-week-fill"></i></span>
                                <div>
                                    <strong>50+</strong>
                                    <small class="d-block text-muted">Weekly classes</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6 gym-hero__content-col gym-reveal gym-reveal--right">
                        <div class="gym-hero__badge">
                            <span class="gym-icon-circle" style="width:28px;height:28px;font-size:0.85rem;border-radius:50%;"><i class="bi bi-lightning-charge-fill"></i></span>
                            <span>120+ members training this week</span>
                        </div>

                        <h1 class="gym-hero__title">
                            Your body can
                            <span>stand almost</span> anything
                        </h1>

                        <p class="gym-hero__lead">
                            It's your mind that needs convincing. Push past your limits, stay committed,
                            and watch your body transform into a powerhouse of strength and resilience.
                        </p>

                        <div class="gym-stats gym-reveal-stagger">
                            <div class="gym-stat">
                                <span class="gym-icon-circle"><i class="bi bi-people-fill"></i></span>
                                <div class="gym-stat__body">
                                    <div class="gym-stat__value" data-count="100">100</div>
                                    <p class="gym-stat__label">Total Members</p>
                                </div>
                            </div>
                            <div class="gym-stat">
                                <span class="gym-icon-circle"><i class="bi bi-person-check-fill"></i></span>
                                <div class="gym-stat__body">
                                    <div class="gym-stat__value" data-count="85">85</div>
                                    <p class="gym-stat__label">Active Members</p>
                                </div>
                            </div>
                            <div class="gym-stat">
                                <span class="gym-icon-circle"><i class="bi bi-person-workspace"></i></span>
                                <div class="gym-stat__body">
                                    <div class="gym-stat__value" data-count="20">20</div>
                                    <p class="gym-stat__label">Trainers</p>
                                </div>
                            </div>
                            <div class="gym-stat">
                                <span class="gym-icon-circle"><i class="bi bi-calendar-plus-fill"></i></span>
                                <div class="gym-stat__body">
                                    <div class="gym-stat__value" data-count="3">3</div>
                                    <p class="gym-stat__label">Upcoming Sessions</p>
                                </div>
                            </div>
                            <div class="gym-stat">
                                <span class="gym-icon-circle"><i class="bi bi-play-circle-fill"></i></span>
                                <div class="gym-stat__body">
                                    <div class="gym-stat__value" data-count="5">5</div>
                                    <p class="gym-stat__label">Ongoing Sessions</p>
                                </div>
                            </div>
                            <div class="gym-stat">
                                <span class="gym-icon-circle"><i class="bi bi-patch-check-fill"></i></span>
                                <div class="gym-stat__body">
                                    <div class="gym-stat__value" data-count="20">20</div>
                                    <p class="gym-stat__label">Completed Sessions</p>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-3">
                            <a href="#" class="gym-btn gym-btn--primary">
                                Get Started <i class="bi bi-rocket-takeoff-fill"></i>
                            </a>
                            <a href="#about" class="gym-btn gym-btn--outline"><i class="bi bi-compass-fill"></i> Explore More</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- News ticker -->
        <div class="gym-news-bar" aria-label="Gym announcements">
            <div class="gym-news-bar__label">
                <span class="gym-news-bar__pulse" aria-hidden="true"></span>
                Live
            </div>
            <div class="gym-news-bar__viewport">
                <div class="gym-news-bar__fade gym-news-bar__fade--left" aria-hidden="true"></div>
                <div class="gym-news-bar__track">
                    <span class="gym-news-bar__chip"><i class="bi bi-brightness-alt-high-fill"></i> Outdoor &amp; online trainers</span>
                    <span class="gym-news-bar__chip"><i class="bi bi-person-arms-up"></i> Personal training</span>
                    <span class="gym-news-bar__chip"><i class="bi bi-camera-video-fill"></i> Live classes</span>
                    <span class="gym-news-bar__chip"><i class="bi bi-award-fill"></i> Expert coaches</span>
                    <span class="gym-news-bar__chip"><i class="bi bi-cup-hot-fill"></i> Nutrition plans</span>
                    <span class="gym-news-bar__chip"><i class="bi bi-brightness-alt-high-fill"></i> Outdoor &amp; online trainers</span>
                    <span class="gym-news-bar__chip"><i class="bi bi-person-arms-up"></i> Personal training</span>
                    <span class="gym-news-bar__chip"><i class="bi bi-camera-video-fill"></i> Live classes</span>
                    <span class="gym-news-bar__chip"><i class="bi bi-award-fill"></i> Expert coaches</span>
                    <span class="gym-news-bar__chip"><i class="bi bi-cup-hot-fill"></i> Nutrition plans</span>
                </div>
                <div class="gym-news-bar__fade gym-news-bar__fade--right" aria-hidden="true"></div>
            </div>
        </div>

        <!-- About -->
        <section class="gym-about" id="about">
            <div class="container">
                <div class="row align-items-center g-5">
                    <div class="col-lg-6 gym-about__text-col gym-reveal">
                        <span class="gym-section-label">
                            <i class="bi bi-barbell"></i> About Us
                        </span>
                        <h2 class="gym-section-title">
                            Empowering you to achieve
                            <span class="highlight">your fitness</span> goals
                        </h2>
                        <p class="gym-section-text">
                            We believe fitness is more than just a workout—it's a lifestyle. With top-of-the-line
                            facilities, certified trainers, and a supportive community, we're here to inspire
                            and guide you every step of the way.
                        </p>

                        <div class="gym-feature-grid gym-reveal-stagger">
                            <article class="gym-feature-card">
                                <div class="gym-feature-card__icon"><i class="bi bi-person-raised-hand"></i></div>
                                <h3>Personal Trainer</h3>
                                <p>One-on-one coaching tailored to your goals and fitness level.</p>
                            </article>
                            <article class="gym-feature-card">
                                <div class="gym-feature-card__icon"><i class="bi bi-hdd-stack-fill"></i></div>
                                <h3>Modern Equipment</h3>
                                <p>State-of-the-art machines and free weights for every training style.</p>
                            </article>
                            <article class="gym-feature-card">
                                <div class="gym-feature-card__icon"><i class="bi bi-bezier2"></i></div>
                                <h3>Group Classes</h3>
                                <p>High-energy sessions that keep you motivated and accountable.</p>
                            </article>
                            <article class="gym-feature-card">
                                <div class="gym-feature-card__icon"><i class="bi bi-heart-pulse-fill"></i></div>
                                <h3>Wellness Plans</h3>
                                <p>Holistic programs combining training, recovery, and nutrition.</p>
                            </article>
                        </div>

                        <a href="#" class="gym-btn gym-btn--primary mt-4">
                            Get Started <i class="bi bi-arrow-right-circle-fill"></i>
                        </a>
                    </div>

                    <div class="col-lg-6 gym-about__gallery-col gym-reveal gym-reveal--right">
                        <div class="gym-about__gallery">
                            <div class="gym-about__img gym-about__img--main">
                                <img src="~/images/home/about-main.jpg" alt="Modern gym floor with equipment" />
                                <span class="gym-about__img-badge"><i class="bi bi-geo-alt-fill"></i> Premium facility</span>
                            </div>
                            <div class="gym-about__img gym-about__img--secondary">
                                <img src="~/images/home/about-side1.jpg" alt="Group fitness class" />
                            </div>
                            <div class="gym-about__img gym-about__img--tertiary">
                                <img src="~/images/home/about-side2.jpg" alt="Cardio and strength zone" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Workouts -->
        <section class="gym-workouts" id="workouts">
            <div class="container">
                <header class="gym-workouts__header gym-reveal">
                    <span class="gym-workouts__tag">WORKOUTS</span>
                    <h2><i class="bi bi-fire me-2"></i>Transform your body with our dynamic upcoming workouts</h2>
                </header>

                <div class="row g-4 gym-reveal-stagger">
                    <div class="col-md-4">
                        <article class="gym-workout-card">
                            <div class="gym-workout-card__media">
                                <span class="gym-workout-card__badge"><i class="bi bi-people-fill"></i> Group</span>
                                <img src="~/images/home/workout-group.jpg" alt="Group workout session" />
                                <div class="gym-workout-card__overlay"></div>
                            </div>
                            <div class="gym-workout-card__body">
                                <h3><i class="bi bi-people-fill me-1"></i> Group Workout</h3>
                                <a href="#" class="gym-workout-card__link" aria-label="Explore group workout">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                            </div>
                        </article>
                    </div>
                    <div class="col-md-4">
                        <article class="gym-workout-card">
                            <div class="gym-workout-card__media">
                                <span class="gym-workout-card__badge"><i class="bi bi-speedometer2"></i> HIIT</span>
                                <img src="~/images/home/workout-hiit.jpg" alt="HIIT training" />
                                <div class="gym-workout-card__overlay"></div>
                            </div>
                            <div class="gym-workout-card__body">
                                <h3><i class="bi bi-lightning-charge-fill me-1"></i> HIIT Training</h3>
                                <a href="#" class="gym-workout-card__link" aria-label="Explore HIIT training">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                            </div>
                        </article>
                    </div>
                    <div class="col-md-4">
                        <article class="gym-workout-card">
                            <div class="gym-workout-card__media">
                                <span class="gym-workout-card__badge"><i class="bi bi-trophy-fill"></i> Strength</span>
                                <img src="~/images/home/workout-strength.jpg" alt="Strength training" />
                                <div class="gym-workout-card__overlay"></div>
                            </div>
                            <div class="gym-workout-card__body">
                                <h3><i class="bi bi-barbell me-1"></i> Strength Training</h3>
                                <a href="#" class="gym-workout-card__link" aria-label="Explore strength training">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                            </div>
                        </article>
                    </div>
                </div>

                <div class="gym-workouts__dots" role="tablist" aria-label="Workout carousel">
                    <button type="button" class="gym-workouts__dot" aria-label="Slide 1"></button>
                    <button type="button" class="gym-workouts__dot active" aria-label="Slide 2"></button>
                    <button type="button" class="gym-workouts__dot" aria-label="Slide 3"></button>
                    <button type="button" class="gym-workouts__dot" aria-label="Slide 4"></button>
                </div>
            </div>
        </section>

        <!-- Why Us -->
        <section class="gym-why" id="why-us">
            <div class="container">
                <div class="row align-items-center g-5">
                    <div class="col-lg-6 gym-why__visual-col gym-reveal gym-reveal--left">
                        <div class="gym-why__collage">
                            <div class="gym-why__collage-stat">
                                <span class="gym-icon-circle"><i class="bi bi-graph-up-arrow"></i></span>
                                <div>
                                    <strong>98%</strong>
                                    <span>Member satisfaction</span>
                                </div>
                            </div>
                            <div class="gym-why__collage-main">
                                <img src="~/images/home/why-visual.jpg" alt="Trainer helping member with exercise form" />
                            </div>
                            <div class="gym-why__collage-float d-none d-sm-block">
                                <img src="~/images/home/about-side2.jpg" alt="Active gym community" />
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6 gym-why__content-col gym-reveal gym-reveal--right">
                        <span class="gym-section-label">
                            <i class="bi bi-patch-check-fill"></i> Why Us
                        </span>
                        <h2 class="gym-section-title">
                            Elevate fitness with
                            <span class="highlight">the best</span> way possible
                        </h2>
                        <p class="gym-section-text">
                            We believe fitness is more than just a workout—it's a lifestyle. With top-of-the-line
                            facilities, certified trainers, and a supportive community, we're here to inspire
                            and guide you every step of the way.
                        </p>

                        <ul class="gym-why__steps gym-reveal-stagger">
                            <li class="gym-why__step">
                                <span class="gym-why__step-icon"><i class="bi bi-sliders"></i></span>
                                <div>
                                    <h3>Personalized fitness plans</h3>
                                    <p>Every workout is tailored to your unique goals and fitness level so you make real progress.</p>
                                </div>
                            </li>
                            <li class="gym-why__step">
                                <span class="gym-why__step-icon"><i class="bi bi-mortarboard-fill"></i></span>
                                <div>
                                    <h3>Certified expert trainers</h3>
                                    <p>Learn from professionals who combine experience, science, and motivation in every session.</p>
                                </div>
                            </li>
                            <li class="gym-why__step">
                                <span class="gym-why__step-icon"><i class="bi bi-calendar2-check-fill"></i></span>
                                <div>
                                    <h3>Flexible scheduling</h3>
                                    <p>Book sessions that fit your life—early mornings, lunch breaks, or evening pushes.</p>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    </main>


    <button type="button" class="gym-back-top" aria-label="Back to top">
        <i class="bi bi-arrow-up"></i>
    </button>

</body>

</html>

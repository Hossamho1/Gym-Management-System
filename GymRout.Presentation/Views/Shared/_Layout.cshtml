<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Power Fitness — Transform your body with expert trainers, modern equipment, and a supportive community." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..700;1,14..32,300..700&family=Plus+Jakarta+Sans:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="~/css/home.css" />
    <title>Power Fitness | Home</title>
    <script>document.documentElement.classList.add('gym-js');</script>
</head>

<body>
    @await Html.PartialAsync("_Header")

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="gym-footer-light bg-white border-top pt-5 pb-3 mt-5">
        <div class="container main-footer-content">
            <div class="row g-4 g-lg-5 mb-5">
                <div class="col-sm-6 col-lg-3">
                    <div class="footer-brand mb-4">
                        <img src="~/images/logo.jpg" alt="Power Fitness logo" class="footer-logo mb-3 rounded" style="max-width: 120px;" />
                        <p class="text-muted"><i class="bi bi-quote fs-4 text-primary opacity-50 me-1"></i>Push harder, go further. Your fitness journey starts today.</p>
                    </div>
                    <div class="social-links d-flex gap-2">
                        <a href="#" class="btn btn-primary btn-sm rounded-circle" style="width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center;"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-primary btn-sm rounded-circle" style="width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center;"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="btn btn-primary btn-sm rounded-circle" style="width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center;"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="btn btn-primary btn-sm rounded-circle" style="width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center;"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-3">
                    <h5 class="text-dark text-uppercase mb-4 fw-bold">Contact Us</h5>
                    <ul class="list-unstyled d-flex flex-column gap-3">
                        <li class="d-flex align-items-start gap-3">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; min-width: 40px;">
                                <i class="bi bi-telephone-fill"></i>
                            </div>
                            <span class="text-muted mt-2">+91 123 456 789</span>
                        </li>
                        <li class="d-flex align-items-start gap-3">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; min-width: 40px;">
                                <i class="bi bi-envelope-fill"></i>
                            </div>
                            <span class="text-muted mt-2">info@gmail.com</span>
                        </li>
                    </ul>
                </div>

                <div class="col-sm-6 col-lg-3">
                    <h5 class="text-dark text-uppercase mb-4 fw-bold">Gym Timing</h5>
                    <ul class="list-unstyled d-flex flex-column gap-3">
                        <li class="d-flex align-items-start gap-3">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; min-width: 40px;">
                                <i class="bi bi-sun-fill"></i>
                            </div>
                            <div class="text-muted mt-1">
                                <strong class="d-block text-dark">Mon – Fri</strong>
                                <small>08:00 AM – 10:00 PM</small>
                            </div>
                        </li>
                        <li class="d-flex align-items-start gap-3">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; min-width: 40px;">
                                <i class="bi bi-moon-stars-fill"></i>
                            </div>
                            <div class="text-muted mt-1">
                                <strong class="d-block text-dark">Sat – Sun</strong>
                                <small>08:00 AM – 09:00 PM</small>
                            </div>
                        </li>
                    </ul>
                </div>

                <div class="col-sm-6 col-lg-3">
                    <h5 class="text-dark text-uppercase mb-4 fw-bold">Our Location</h5>
                    <ul class="list-unstyled d-flex flex-column gap-3">
                        <li class="d-flex align-items-start gap-3">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; min-width: 40px;">
                                <i class="bi bi-geo-alt-fill"></i>
                            </div>
                            <span class="text-muted mt-1">2715 Ash Dr. San Jose,<br />South Dakota 83475</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="footer-bottom pt-4 border-top">
            <div class="container text-center">
                <p class="text-muted mb-0 small">&copy; @DateTime.Now.Year Power Fitness. All rights reserved.</p>
            </div>
        </div>
    </footer>
    <script src="@Url.Content("~/lib/bootstrap/dist/js/bootstrap.bundle.js")"></script>
    <script src="@Url.Content("~/js/home.js")" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
@model List<Plan>


<div class="mt-4 mb-5">
    <header class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold" style="color: var(--primary-color, #070093);">Membership Plans</h2>
            <p class="text-muted mb-0">Manage your gym membership packages</p>
        </div>
        <a asp-action="Create" class="get-started text-decoration-none shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Add Plan
        </a>
    </header>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var plan in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 border-0 plan-card" style="border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.04);">

                        <div class="p-4 border-bottom position-relative @(plan.IsActive ? "bg-white" : "bg-light")" style="border-radius: 15px 15px 0 0;">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h4 class="fw-bold mb-0" style="color: var(--primary-color, #070093);">@plan.Name</h4>
                                @if (plan.IsActive)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-1">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary rounded-pill px-3 py-1">Inactive</span>
                                }
                            </div>
                            <div class="mt-3">
                                <span class="display-6 fw-bold" style="color: var(--primary-color, #070093);">@plan.Price.ToString("N0")</span>
                                <span class="text-muted fw-bold"> EGP</span>
                            </div>
                        </div>

                        <div class="card-body p-4 d-flex flex-column @(!plan.IsActive ? "opacity-75" : "")">
                            <ul class="list-unstyled mb-4 flex-grow-1">
                                <li class="d-flex align-items-center mb-3">
                                    <div class="icon-box me-3">
                                        <i class="bi bi-calendar-check" style="color: var(--primary-color, #070093); font-size: 1.2rem;"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Duration</small>
                                        <strong class="text-dark">@plan.DurationDays Days</strong>
                                    </div>
                                </li>
                                <li class="d-flex align-items-start">
                                    <div class="icon-box me-3 mt-1">
                                        <i class="bi bi-file-text" style="color: var(--primary-color, #070093); font-size: 1.2rem;"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Description</small>
                                        <span class="text-dark small" style="line-height: 1.6;">@plan.Description</span>
                                    </div>
                                </li>
                            </ul>

                            <div class="mt-auto">
                                <a asp-controller="Plans" asp-action="Details" asp-route-id="@plan.Id" class="explore-more d-block text-center text-decoration-none py-2 mb-3 w-100 fw-bold">
                                    <i class="bi bi-eye me-1"></i> View Details
                                </a>

                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@plan.Id" class="btn btn-light border flex-fill text-dark">
                                        <i class="bi bi-pencil me-1"></i> Edit
                                    </a>

                                    <form asp-action="@(plan.IsActive ? "Deactivate" : "Activate")" asp-route-id="@plan.Id" method="post" class="flex-fill m-0 p-0">
                                        <button type="submit" class="btn w-100 @(plan.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                            @if (plan.IsActive)
                                            {
                                                <i class="bi bi-x-circle me-1"></i> <span>Deactivate</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-check-circle me-1"></i> <span>Activate</span>
                                            }
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 rounded" style="background-color: rgba(7, 0, 147, 0.03); border: 2px dashed rgba(7, 0, 147, 0.2);">
            <div class="icon-box mx-auto mb-3" style="width: 80px; height: 80px; border-radius: 20px;">
                <i class="bi bi-inbox display-4" style="color: var(--primary-color, #070093);"></i>
            </div>
            <h4 class="fw-bold" style="color: var(--primary-color, #070093);">No Plans Available</h4>
            <p class="text-muted">You haven't added any membership plans yet.</p>
            <a asp-action="Create" class="get-started text-decoration-none mt-2 d-inline-block">
                Create Your First Plan
            </a>
        </div>
    }
</div>
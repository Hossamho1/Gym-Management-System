@model Plan


<div class="mt-4 mb-5">
    <header class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold" style="color: @(Model.IsActive ? "var(--primary-color, #070093)" : "#dc3545");">Plan Details</h2>
            <p class="text-muted mb-0">Review membership package information</p>
        </div>
        <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i> Back to Plans
        </a>
    </header>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 plan-card" style="border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.08);">

                <div class="p-5 text-center position-relative" style="background-color: @(Model.IsActive ? "rgba(7, 0, 147, 0.05)" : "rgba(220, 53, 69, 0.05)"); border-radius: 20px 20px 0 0; border-bottom: 1px dashed rgba(0,0,0,0.1);">
                    <div class="icon-box mx-auto mb-3 bg-white shadow-sm" style="width: 80px; height: 80px; font-size: 2.5rem; border-radius: 20px;">
                        <i class="bi bi-award-fill" style="color: @(Model.IsActive ? "var(--primary-color, #070093)" : "#dc3545");"></i>
                    </div>

                    <h2 class="fw-bold mb-2" style="color: @(Model.IsActive ? "var(--primary-color, #070093)" : "#dc3545");">@Model.Name</h2>

                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-1 mb-3">
                            <i class="bi bi-check-circle-fill me-1"></i> Active Status
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3 py-1 mb-3">
                            <i class="bi bi-x-circle-fill me-1"></i> Inactive Status
                        </span>
                    }

                    <div class="mt-3">
                        <span class="display-3 fw-bold" style="color: @(Model.IsActive ? "var(--primary-color, #070093)" : "#dc3545");">@Model.Price.ToString("N0")</span>
                        <span class="text-muted fw-bold fs-4"> EGP</span>
                    </div>
                </div>

                <div class="card-body p-5 @(!Model.IsActive ? "opacity-75" : "")">
                    <div class="d-flex flex-column gap-4">

                        <div class="d-flex align-items-center">
                            <div class="icon-box me-4 shadow-sm" style="min-width: 60px; height: 60px; border-radius: 15px; background-color: @(Model.IsActive ? "rgba(7, 0, 147, 0.05)" : "rgba(220, 53, 69, 0.05)");">
                                <i class="bi bi-calendar-check" style="color: @(Model.IsActive ? "var(--primary-color, #070093)" : "#dc3545"); font-size: 1.5rem;"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block text-uppercase fw-bold mb-1" style="letter-spacing: 1px; font-size: 0.75rem;">Duration</small>
                                <span class="fs-5 fw-bold text-dark">@Model.DurationDays Days</span>
                            </div>
                        </div>

                        <div class="d-flex align-items-start">
                            <div class="icon-box me-4 mt-1 shadow-sm" style="min-width: 60px; height: 60px; border-radius: 15px; background-color: @(Model.IsActive ? "rgba(7, 0, 147, 0.05)" : "rgba(220, 53, 69, 0.05)");">
                                <i class="bi bi-card-text" style="color: @(Model.IsActive ? "var(--primary-color, #070093)" : "#dc3545"); font-size: 1.5rem;"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block text-uppercase fw-bold mb-2" style="letter-spacing: 1px; font-size: 0.75rem;">Description</small>
                                <p class="text-dark mb-0 fs-6" style="line-height: 1.7;">@Model.Description</p>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="card-footer bg-white border-0 p-4 pb-5" style="border-radius: 0 0 20px 20px;">
                    <div class="d-flex gap-3 px-3">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn text-center text-decoration-none flex-fill fw-bold py-3 shadow-sm rounded-pill text-white" style="background-color: @(Model.IsActive ? "var(--primary-color, #070093)" : "#dc3545"); border-color: @(Model.IsActive ? "var(--primary-color, #070093)" : "#dc3545");">
                            <i class="bi bi-pencil-square me-2"></i> Edit Plan
                        </a>

                        <form asp-action="@(Model.IsActive ? "Deactivate" : "Activate")" asp-route-id="@Model.Id" method="post" class="flex-fill m-0 p-0">
                            <button type="submit" class="btn w-100 fw-bold py-3 text-center rounded-pill @(Model.IsActive ? "btn-outline-danger" : "btn-outline-success")" style="border-width: 2px;">
                                @if (Model.IsActive)
                                {
                                    <i class="bi bi-power me-2"></i> <span>Deactivate</span>
                                }
                                else
                                {
                                    <i class="bi bi-lightning-charge-fill me-2"></i> <span>Activate</span>
                                }
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string IsActive(string controllerName) => 
        string.Equals(controller, controllerName, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<header>
    <nav class="navbar navbar-expand-lg gym-nav" id="gymNav">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2 text-decoration-none" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.jpg" alt="Power Fitness logo" />
                <span class="d-none d-sm-inline fw-bold text-dark" style="font-family: var(--gym-font-display);">Power Fitness</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-1">
                    <li class="nav-item">
                        <a class="nav-link @IsActive("Home")" aria-current="page" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door-fill"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @IsActive("Member")" asp-controller="Member" asp-action="Index">
                            <i class="bi bi-people-fill"></i>Members
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @IsActive("Trainers")" href="#">
                            <i class="bi bi-person-badge-fill"></i>Trainers
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @IsActive("Sessions")" href="#">
                            <i class="bi bi-calendar2-week-fill"></i>Sessions
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @IsActive("Plans")" asp-controller="Plans" asp-action="Index">
                            <i class="bi bi-ui-checks-grid"></i>Plans
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @IsActive("Memberships")" href="#">
                            <i class="bi bi-passport-fill"></i>Memberships
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @IsActive("Schedule")" href="#">
                            <i class="bi bi-clock-history"></i>Schedule
                        </a>
                    </li>
                </ul>
                <form asp-action="Logout" asp-controller="Account" method="post" class="d-flex">
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-right me-1"></i> Logout
                    </button>
                </form>
            </div>
        </div>
    </nav>
</header>